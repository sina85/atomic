{
  "name": "atomic-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "contributors": [
    "Norin Lavaee",
    "Alex Lavaee"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "bun scripts/install-hooks.mjs",
    "hooks:install": "bunx --bun --no-install prek install --prepare-hooks",
    "hooks:run": "bunx --bun --no-install prek run --all-files",
    "test": "bun run test:unit",
    "test:unit": "bun test test/unit",
    "test:integration": "bun test test/integration",
    "test:all": "bun run test:unit && bun run test:integration",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@j178/prek": "0.4.3",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
