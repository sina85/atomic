{
  "name": "@bastani/atomic-monorepo",
  "private": true,
  "version": "0.7.1",
  "description": "Configuration management CLI and SDK for coding agents",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flora131/atomic.git"
  },
  "keywords": [
    "cli",
    "sdk",
    "coding-agents",
    "agents",
    "ai-engineering",
    "harness-engineering",
    "claude-code",
    "copilot-cli",
    "opencode"
  ],
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "bun run packages/atomic/script/ensure-dev-assets.ts && bun run packages/atomic/src/cli.ts",
    "build": "bun run packages/atomic/script/build.ts && bun run packages/atomic-sdk/script/build.ts",
    "test": "bun test --parallel packages tests",
    "test:coverage": "bun test --coverage packages tests",
    "typecheck": "bun --filter '*' typecheck",
    "lint": "oxlint --config=oxlint.json packages",
    "lint:fix": "oxlint --config=oxlint.json --fix packages",
    "prepare": "prek install || true"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.128",
    "@j178/prek": "^0.3.11",
    "@opentui/core": "^0.2.2",
    "@opentui/react": "^0.2.2",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "bun-pty": "0.4.8",
    "oxlint": "^1.62.0",
    "react": "^19.2.5",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.1.3",
    "yaml": "^2.8.4"
  }
}
