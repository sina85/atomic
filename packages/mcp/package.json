{
  "name": "@bastani/mcp",
  "version": "0.8.28",
  "private": true,
  "description": "Atomic extension that adapts MCP (Model Context Protocol) servers into the coding agent. Fork of: https://github.com/nicobailon/pi-mcp-adapter",
  "contributors": [
    "Norin Lavaee",
    "Alex Lavaee"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "bun": ">=1.3.14"
  },
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "*.ts",
    "app-bridge.bundle.js",
    "README.md",
    "OAUTH.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@bastani/atomic": "*",
    "@earendil-works/pi-ai": "^0.78.1",
    "@earendil-works/pi-tui": "^0.78.1",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@bastani/atomic": {
      "optional": true
    },
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.2",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "open": "^11.0.0",
    "typebox": "^1.1.24",
    "zod": "^3.25.0 || ^4.0.0"
  }
}
