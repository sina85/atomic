{
  "name": "@bastani/workflows",
  "version": "0.8.8",
  "private": true,
  "description": "pi extension for multi-stage workflow authoring and execution.",
  "contributors": [
    "Norin Lavaee",
    "Alex Lavaee"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "bun": ">=1.3.14"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./builtin": "./builtin/index.ts",
    "./builtin/*": "./builtin/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flora131/atomic.git",
    "directory": "packages/workflows"
  },
  "homepage": "https://github.com/flora131/atomic/tree/main/packages/workflows#readme",
  "bugs": {
    "url": "https://github.com/flora131/atomic/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "workflow",
    "orchestration",
    "ai",
    "cli"
  ],
  "files": [
    "src/**/*.ts",
    "builtin/**/*.ts",
    "skills/**/*",
    "prompts/**/*",
    "themes/*.json",
    "assets/**/*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun run test:unit",
    "test:unit": "bun test ../../test/unit",
    "test:integration": "bun test ../../test/integration",
    "test:all": "bun run test:unit && bun run test:integration",
    "typecheck": "tsc --noEmit -p ../../tsconfig.json",
    "lint": "tsc --noEmit -p ../../tsconfig.json"
  },
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ],
    "builtin": [
      "./builtin"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [],
    "themes": [
      "themes/*.json"
    ]
  },
  "peerDependencies": {
    "@bastani/atomic": "*",
    "@earendil-works/pi-tui": "*"
  },
  "peerDependenciesMeta": {
    "@bastani/atomic": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  }
}
